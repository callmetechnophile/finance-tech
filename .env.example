# ==============================================================================
# FORGE-PATH FINANCIAL OPERATING SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env.local (frontend) or .env (backend) and fill in values.
# NEVER commit sensitive API keys, database URLs, or secret tokens into Git.
# ==============================================================================

# ─── FRONTEND (BROWSER-SAFE ONLY - MUST BE PREFIXED WITH NEXT_PUBLIC_) ────────
NEXT_PUBLIC_APP_NAME="FORGE-PATH AI Financial OS"
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/login

# ─── BACKEND DATABASE (NEON POSTGRESQL) ───────────────────────────────────────
DATABASE_URL=
DATABASE_URL_UNPOOLED=
NEON_DATABASE_URL=
NEON_BRANCH=production
NEON_AUTH_BASE_URL=
NEON_AUTH_JWKS_URL=

# ─── BACKEND AUTHENTICATION & SECURITY ───────────────────────────────────────
CLERK_SECRET_KEY=
JWT_SECRET=
SECRET_KEY=
APP_NAME="FORGE-PATH Financial Operations API"
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=True
API_V1_STR=/api/v1

# ─── FILE STORAGE (SUPABASE STORAGE) ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=financial-documents

# ─── AI INFERENCE (GOOGLE AI STUDIO - GEMMA 4 MODEL) ──────────────────────────
GOOGLE_API_KEY=
GOOGLE_AI_MODEL=gemma-4
GOOGLE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ─── OCR PROCESSING ──────────────────────────────────────────────────────────
OCR_ENGINE=paddle_ocr

# ─── COMMUNICATIONS (TWILIO & BREVO) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# ─── GRAPH DATABASE (NEO4J / AURADB) ─────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ─── ANALYTICS DATABASE (CLICKHOUSE) ─────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── CACHE & BROKER (REDIS) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
