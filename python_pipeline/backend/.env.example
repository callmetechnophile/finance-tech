# ─── BACKEND ENVIRONMENT TEMPLATE ─────────────────────────────────────────────
APP_NAME="FORGE-PATH Financial Operations API"
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=True
API_V1_STR=/api/v1
SECRET_KEY=
JWT_SECRET=

# ─── AUTHENTICATION (CLERK SERVER SECRET) ────────────────────────────────────
CLERK_SECRET_KEY=

# ─── BUSINESS DATABASE (NEON POSTGRESQL) ─────────────────────────────────────
DATABASE_URL=
NEON_DATABASE_URL=
NEON_BRANCH=production
NEON_AUTH_BASE_URL=
NEON_AUTH_JWKS_URL=

# ─── FILE STORAGE (SUPABASE STORAGE) ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=financial-documents

# ─── AI INFERENCE (NVIDIA NIM + GEMMA) ───────────────────────────────────────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/gemma-4-31b-it
GEMMA_API_KEY=

# ─── OCR PROCESSING ──────────────────────────────────────────────────────────
OCR_ENGINE=paddle_ocr

# ─── COMMUNICATIONS (TWILIO & BREVO) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# ─── GRAPH DATABASE (NEO4J / AURADB) ─────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ─── ANALYTICS DATABASE (CLICKHOUSE) ─────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── CACHE & BROKER (REDIS) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
